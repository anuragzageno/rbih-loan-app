            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicant\": {\n    \"name\": \"\",\n    \"age\": 15,\n    \"monthlyIncome\": -1000,\n    \"employmentType\": \"SALARIED\",\n    \"creditScore\": 50\n  },\n  \"loan\": {\n    \"amount\": 100,\n    \"tenureMonths\": 2,\n    \"purpose\": \"PERSONAL\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Multiple field errors returned at once', () => {",
                  "    pm.expect(pm.response.json().fieldErrors.length).to.be.at.least(3);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
